Scenario: 2 you have two buttons and each handles it own state on click. But this time the state should be handled in parent and not in child. This is called lifting up the state.
import  { useState },React from 'react';

export default function App() {
  const [count, setCount] = useState([0, 0]);

  function btnClick(index) {
    setCount((elem) => elem.map((val, i) => i === index ? val + 1 : val));
  }
  function MyButton({ value, handleClick }) {
    return (
      <>
        <button onClick={handleClick}>clicked</button>
        <p>{value}</p>
      </>
    );
  }

  return (
    <div>
      <MyButton value={count[0]} handleClick={()=>btnClick(0)} />
      <MyButton value={count[1]} handleClick={()=>btnClick(1)} />
    </div>
  );
}
Counters that update separately
Clicked ->2 times
Clicked ->3 times
